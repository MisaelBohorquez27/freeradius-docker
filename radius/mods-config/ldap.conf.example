# =============================================================\n# Configuración LDAP para FreeRADIUS\n# Integración con Microsoft Active Directory\n# =============================================================\n# NOTA: Esta es una configuración de referencia para Fase 2\n# Descomentar y ajustar cuando se integre con AD\n# =============================================================\n\nldap {\n    # ==========================================================\n    # CONEXIÓN AL SERVIDOR LDAP/AD\n    # ==========================================================\n    \n    # Servidor LDAP (Active Directory)\n    # Ejemplos:\n    #   - ldap.example.com\n    #   - dc01.example.com\n    #   - 192.168.1.50\n    # server = \"ldap.example.com\"\n    \n    # Puerto LDAP (389) o LDAPS (636 - con SSL)\n    # port = 389\n    # use_tls = no\n    \n    # Para LDAPS (recomendado en producción)\n    # port = 636\n    # use_tls = yes\n    # tls_ca_file = \"/etc/freeradius/3.0/certs/ca.crt\"\n    \n    # ==========================================================\n    # CREDENCIALES DE CONEXIÓN\n    # ==========================================================\n    \n    # Usuario con permiso para consultar AD\n    # Formato: usuario@dominio.com o CN=usuario,OU=...,DC=...\n    # bind_dn = \"radius@example.com\"\n    # bind_password = \"PasswordSegura123!\"\n    \n    # Para LDAP anónimo (no recomendado):\n    # Anonymous = yes\n    \n    # ==========================================================\n    # BÚSQUEDA DE USUARIOS\n    # ==========================================================\n    \n    # Base DN (punto de inicio de búsqueda)\n    # Ejemplos:\n    #   - DC=example,DC=com\n    #   - OU=Users,DC=example,DC=com\n    # base_dn = \"DC=example,DC=com\"\n    \n    # Filtro de búsqueda de usuarios\n    # %u = nombre de usuario ingresado\n    # %{Exec-Program-Wait:/path/to/script} = ejecutar script\n    # filter = \"(&(objectClass=user)(sAMAccountName=%u))\"\n    \n    # Atributos a obtener\n    # update {\n    #     control:Password-With-Header := 'userPassword'\n    #     request:Calling-Station-Id := 'ipAddress'\n    # }\n    \n    # ==========================================================\n    # SINCRONIZACIÓN DE GRUPOS\n    # ==========================================================\n    \n    # Para autorizar por grupos:\n    # group_da = \"ou=Groups,DC=example,DC=com\"\n    # group_filter = \"(&(objectClass=group)(cn=%g))\"\n    # group_membership_filter = \"(&(objectClass=user)(memberOf=%D))\"\n    \n    # ==========================================================\n    # OPCIONES DE SEGURIDAD\n    # ==========================================================\n    \n    # Timeout de conexión\n    # timeout = 10\n    \n    # Número de reintentos\n    # retry_delay = 1\n    # rebind = yes\n    \n    # Pool de conexiones\n    # pool {\n    #     start = 5\n    #     min = 3\n    #     max = 10\n    #     spare = 3\n    #     uses = 0\n    #     lifetime = 3600\n    #     cleanup_interval = 300\n    # }\n    \n    # ==========================================================\n    # CERTIFICADOS TLS (LDAPS)\n    # ==========================================================\n    \n    # tls {\n    #     ca_file = \"/etc/freeradius/3.0/certs/ca.crt\"\n    #     certfile = \"/etc/freeradius/3.0/certs/client.crt\"\n    #     keyfile = \"/etc/freeradius/3.0/certs/client.key\"\n    #     require_cert = \"hard\"  # hard, soft, allow, deny\n    # }\n}\n\n# =============================================================\n# EJEMPLO DE CONFIGURACIÓN COMPLETA PARA PRODUCCIÓN\n# =============================================================\n# \n# ldap {\n#     server = \"dc01.example.com\"\n#     port = 636\n#     use_tls = yes\n#     tls_ca_file = \"/etc/freeradius/3.0/certs/ad-ca.crt\"\n#     tls_require_cert = \"demand\"\n#     \n#     bind_dn = \"CN=radius_service,OU=ServiceAccounts,DC=example,DC=com\"\n#     bind_password = \"RadiusServicePassword123!\"\n#     \n#     base_dn = \"DC=example,DC=com\"\n#     filter = \"(&(objectClass=user)(sAMAccountName=%u))\"\n#     \n#     timeout = 10\n#     \n#     pool {\n#         start = 10\n#         min = 5\n#         max = 20\n#         spare = 5\n#     }\n# }\n# \n# =============================================================\n"